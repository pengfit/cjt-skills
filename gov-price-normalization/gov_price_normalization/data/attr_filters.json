{
  "_meta": {
    "version": "0.3.4",
    "updated": "2026-07-22",
    "note": "v0.3.0: 扩 desc_v 系列规则 — material/color 字段加括号/标点开头结尾拒绝、多维尺寸拒绝、描述词拒绝、超长拒绝;grade/series 多维拒绝。覆盖 2026-07-22 norm 抽样审计发现的 3.27% 真实脏数据。 v0.3.1 增 forbidden_type_phrases：(治本) 防跨品种 type 字符串串入石材/钢/材类品种（详 2026-07-22 碎石+消防串料事件） v0.3.2 增 forbidden_type_phrases: 西朗/标线漆/防水涂料/DC12V (治本:detector v0.14 标真 bug 3 类) v0.3.3 增 forbidden_type_phrases: 厂家/厂 (jilin 规格+品牌串到 type 治本) v0.3.4 增 hard_reject type: 多属性 ;/，/: 分隔超长、末尾右括号截断（DWS 串入 fix）"
  },
  "hard_reject": [
    {
      "key": "type",
      "min_len": 2,
      "reason": "type 字段值过短(单字母如 'm' 是 mm/m²/m³ 误填)"
    },
    {
      "key": "price",
      "reason": "price 是业务顶层字段, 不应出现在 attr"
    },
    {
      "key": "weight",
      "value_contains": "g/m²",
      "reason": "g/m² 是面积密度单位(防水卷材类), 不应作为重量"
    },
    {
      "key": "diameter",
      "value_contains": [
        "mm²",
        "cm²",
        "m²"
      ],
      "reason": "mm²/cm²/m² 是面积单位, 不是直径"
    },
    {
      "key": "outer_diameter",
      "value_contains": [
        "mm²",
        "cm²",
        "m²"
      ],
      "reason": "mm²/cm²/m² 是面积单位"
    },
    {
      "key": "inner_diameter",
      "value_contains": [
        "mm²",
        "cm²",
        "m²"
      ],
      "reason": "mm²/cm²/m² 是面积单位"
    },
    {
      "key": "core_count",
      "value_regex": "^\\d{4,}$",
      "reason": "core_count >999 不合理, 可能是错位(截面积等)"
    },
    {
      "key": "material",
      "value_regex": "^-",
      "reason": "material 不该是负值 (catch-all 把数字段当材质)"
    },
    {
      "key": "material",
      "value_contains": "m³",
      "reason": "m³ 是体积单位, 不该出现在 material 值里"
    },
    {
      "key": "material",
      "value_contains": [
        "/  /",
        " / / "
      ],
      "reason": "material 出现 '/ / ' 是价格文本污染 (如 'm³ / / 155.00 159.65')"
    },
    {
      "key": "type",
      "value_regex": "^[0-9]+[-/][0-9]+$",
      "reason": "type 字段是数字范围 (如 '5-20') 是粒径范围, catch-all 误填"
    },
    {
      "key": "material",
      "value_regex": "^[（(，,、]",
      "reason": "material 字段以标点开头 — 规格描述截尾污染"
    },
    {
      "key": "material",
      "value_regex": "[）)\\}]$",
      "reason": "material 字段以右括号结尾 — 规格描述截头污染"
    },
    {
      "key": "material",
      "value_regex": "\\d+\\s*[×*xX]\\s*\\d+",
      "reason": "material 含多维尺寸(如 200*200*40)— catch-all 把规格段塞到 material"
    },
    {
      "key": "material",
      "value_regex": "(厚度|板厚|壁厚|粒径|强度等级|管道|电线|电缆|钢筋|圆钢|扁钢|角钢|钢材|板材|成活价|详见|参见)",
      "reason": "material 含尺寸/材质描述词 — 是规格描述污染"
    },
    {
      "key": "material",
      "max_len": 25,
      "reason": "material 字段超长(>25字符), 大概率是规格描述污染"
    },
    {
      "key": "color",
      "value_regex": "^[（(，,、]",
      "reason": "color 字段以标点开头 — 规格描述截尾污染"
    },
    {
      "key": "color",
      "value_regex": "[）)\\}]$",
      "reason": "color 字段以右括号结尾 — 规格描述截头污染"
    },
    {
      "key": "color",
      "value_regex": "\\d+\\s*[×*xX]\\s*\\d+",
      "reason": "color 含多维尺寸 — catch-all 把规格段塞到 color"
    },
    {
      "key": "color",
      "max_len": 25,
      "reason": "color 字段超长(>25字符), 大概率是规格描述污染"
    },
    {
      "key": "grade",
      "value_regex": "\\d+\\s*[×*xX]\\s*\\d+",
      "reason": "grade 含多维尺寸 — 是规格污染"
    },
    {
      "key": "series",
      "value_regex": "\\d+\\s*[×*xX]\\s*\\d+",
      "reason": "series 含多维尺寸 — 是规格污染"
    },
    {
      "key": "type",
      "value_contains": [
        ";",
        "，",
        "："
      ],
      "reason": "type 字段疑似 spec 多属性串入(长度>25 或 含全角分隔符)"
    },
    {
      "key": "type",
      "value_regex": ".+[)）]$",
      "reason": "type 字段末尾是右括号 — 疑似 DWS 字段截断/串入"
    },
    {
      "key": "type",
      "value_regex": "^[^;]{1,40};[^;]{1,40};",
      "reason": "type 字段多属性用 ; 分隔 — DWS 应拆分到 thickness/series/coating 等字段"
    }
  ],
