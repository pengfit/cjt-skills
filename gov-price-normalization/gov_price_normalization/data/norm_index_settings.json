{
  "_meta": {
    "version": "0.1.0",
    "updated": "2026-07-08",
    "note": "NORM 索引 settings + mapping。Normalizer ETL 创建 norm_{city}_price 索引时使用。所有字段尽量按 ES 默认 dynamic mapping 不冲突时保留；这里只声明需要特殊处理的字段。"
  },
  "settings": {
    "number_of_shards": 1,
    "number_of_replicas": 0,
    "refresh_interval": "30s"
  },
  "mappings": {
    "dynamic": "true",
    "properties": {
      "_dws_id":         { "type": "keyword" },
      "_norm": {
        "properties": {
          "version":        { "type": "keyword" },
          "city":           { "type": "keyword" },
          "l3_code":        { "type": "keyword" },
          "built_at":       { "type": "date" },
          "status":         { "type": "object", "enabled": true }
        }
      },
      "canonical_period":  { "type": "keyword" },
      "canonical_unit":    { "type": "keyword" },
      "canonical_price":   { "type": "double" },
      "breed":             { "type": "keyword" },
      "spec":              { "type": "keyword" },
      "unit":              { "type": "keyword" },
      "province":          { "type": "keyword" },
      "city":              { "type": "keyword" },
      "county":            { "type": "keyword" },
      "period_start":      { "type": "date" },
      "period_end":        { "type": "date" },
      "price":             { "type": "double" },
      "period_norm": {
        "properties": {
          "raw":          { "type": "keyword" },
          "parsed":       { "type": "date" },
          "canonical":    { "type": "keyword" },
          "year":         { "type": "integer" },
          "month":        { "type": "integer" },
          "quarter":      { "type": "integer" },
          "granularity":  { "type": "keyword" }
        }
      },
      "unit_norm": {
        "properties": {
          "raw":          { "type": "keyword" },
          "dim":          { "type": "keyword" },
          "to_base":      { "type": "double" },
          "base":         { "type": "keyword" },
          "normalized":   { "type": "keyword" }
        }
      },
      "price_norm": {
        "properties": {
          "price_canonical": { "type": "double" },
          "unit_canonical":  { "type": "keyword" },
          "converted":       { "type": "boolean" },
          "factor":          { "type": "double" }
        }
      }
    }
  }
}