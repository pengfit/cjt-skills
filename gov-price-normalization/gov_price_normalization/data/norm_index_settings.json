{
  "_meta": {
    "version": "0.2.0",
    "updated": "2026-07-22",
    "note": "v0.2.0: 加 attr_norm (nested) + cable_canonical (object) + dropped_attrs 追溯字段。L1 attr 净化 + 电缆型号归一数据需要 nested query 支持。"
  },
  "settings": {
    "number_of_shards": 1,
    "number_of_replicas": 0,
    "refresh_interval": "30s"
  },
  "mappings": {
    "dynamic": "true",
    "properties": {
      "_dws_id":         { "type": "keyword" },
      "_norm": {
        "properties": {
          "version":        { "type": "keyword" },
          "city":           { "type": "keyword" },
          "l3_code":        { "type": "keyword" },
          "built_at":       { "type": "date" },
          "status":         { "type": "object", "enabled": true }
        }
      },
      "canonical_period":  { "type": "keyword" },
      "canonical_unit":    { "type": "keyword" },
      "canonical_price":   { "type": "double" },
      "breed":             { "type": "keyword" },
      "normalized_breed":  {
        "type": "text",
        "fields": { "keyword": { "type": "keyword", "ignore_above": 256 } }
      },
      "breed_clean":       { "type": "keyword" },
      "_l3_code":          { "type": "keyword" },
      "_canonical_source": {
        "type": "text",
        "fields": { "keyword": { "type": "keyword", "ignore_above": 64 } }
      },
      "_canonical_confidence": { "type": "float" },
      "spec":              { "type": "keyword" },
      "unit":              { "type": "keyword" },
      "province":          { "type": "keyword" },
      "city":              { "type": "keyword" },
      "county":            { "type": "keyword" },
      "period_start":      { "type": "date" },
      "period_end":        { "type": "date" },
      "price":             { "type": "double" },
      "period_norm": {
        "properties": {
          "raw":          { "type": "keyword" },
          "parsed":       { "type": "date" },
          "canonical":    { "type": "keyword" },
          "year":         { "type": "integer" },
          "month":        { "type": "integer" },
          "quarter":      { "type": "integer" },
          "granularity":  { "type": "keyword" }
        }
      },
      "unit_norm": {
        "properties": {
          "raw":          { "type": "keyword" },
          "dim":          { "type": "keyword" },
          "to_base":      { "type": "double" },
          "base":         { "type": "keyword" },
          "normalized":   { "type": "keyword" }
        }
      },
      "price_norm": {
        "properties": {
          "price_canonical": { "type": "double" },
          "unit_canonical":  { "type": "keyword" },
          "converted":       { "type": "boolean" },
          "factor":          { "type": "double" }
        }
      },
      "attr_norm": {
        "type": "nested",
        "properties": {
          "k": { "type": "keyword" },
          "v": { "type": "keyword" }
        }
      },
      "cable_canonical": {
        "properties": {
          "applied":        { "type": "boolean" },
          "canonical_type": { "type": "keyword" },
          "voltage":        { "type": "keyword" },
          "core_count":     { "type": "integer" },
          "cross_section":  { "type": "keyword" },
          "fire_rating":    { "type": "keyword" },
          "armor_type":     { "type": "keyword" },
          "drop_keys":      { "type": "keyword" },
          "source_spec":    { "type": "keyword" }
        }
      },
      "_norm": {
        "properties": {
          "version":        { "type": "keyword" },
          "city":           { "type": "keyword" },
          "l3_code":        { "type": "keyword" },
          "built_at":       { "type": "date" },
          "status":         { "type": "object", "enabled": false },
          "dropped_attrs":  { "type": "object", "enabled": false },
          "promoted_attrs": { "type": "object", "enabled": false }
        }
      }
    }
  }
}