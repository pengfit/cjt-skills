{
  "meta": {
    "description": "规格解析测试集，每条包含输入spec和期望的attr输出",
    "version": "1.0",
    "city": "xian"
  },
  "test_cases": [
    {"spec": "PN1.6DN150",  "category": "管材管件",       "expected": {"pressure": "PN1.6", "diameter": "DN150"}},
    {"spec": "PN1.6DN200",  "category": "管材管件",       "expected": {"pressure": "PN1.6", "diameter": "DN200"}},
    {"spec": "PN1.6DN100",  "category": "管材管件",       "expected": {"pressure": "PN1.6", "diameter": "DN100"}},
    {"spec": "下出水",       "category": "陶瓷/卫生洁具",  "expected": {"drain_type": "下出水"}},
    {"spec": "后进后出",     "category": "陶瓷/卫生洁具",  "expected": {"drain_type": "后进后出"}},
    {"spec": "后进水地排水",  "category": "陶瓷/卫生洁具",  "expected": {"drain_type": "地排水", "inlet_type": "后进水"}},
    {"spec": "四柱813型H=800", "category": "铁艺/铸铁件", "expected": {"form": "四柱813型", "height": "800mm"}},
    {"spec": "四柱760型H=600", "category": "铁艺/铸铁件", "expected": {"form": "四柱760型", "height": "600mm"}},
    {"spec": "长度1500",     "category": "钢材",           "expected": {"length": "1500mm"}},
    {"spec": "DN100",        "category": "管材管件",       "expected": {"diameter": "DN100"}},
    {"spec": "D325*8*6000",  "category": "管材管件",       "expected": {"diameter": "D325", "thickness": "8mm", "length": "6000mm"}},
    {"spec": "C30",          "category": "水泥",           "expected": {"grade": "C30"}},
    {"spec": "P.O42.5R",     "category": "水泥",           "expected": {"grade": "P.O42.5R"}},
    {"spec": "PVC",           "category": "管材管件",       "expected": {"material": "PVC"}},
    {"spec": "φ800",         "category": "管材管件",       "expected": {"diameter": "Φ800"}},
    {"spec": "δ4",           "category": "钢材",           "expected": {"thickness": "δ4"}},
    {"spec": "厚度3mm",       "category": "钢材",           "expected": {"thickness": "3mm"}},
    {"spec": "IP65",          "category": "电气材料",       "expected": {"ip_rating": "IP65"}},
    {"spec": "380V",          "category": "电气材料",       "expected": {"voltage": "380"}},
    {"spec": "16A",           "category": "电气材料",       "expected": {"current": "16"}},
    {"spec": "台下盆",        "category": "陶瓷/卫生洁具",  "expected": {"installation_type": "台下盆"}},
    {"spec": "AC-13",         "category": "沥青/石材",       "expected": {"asphalt_type": "AC-13"}},
    {"spec": "86型",          "category": "电气材料",       "expected": {"form": "86型"}},
    {"spec": "下出水含铜",     "category": "陶瓷/卫生洁具",  "expected": {"drain_type": "下出水", "material": "铜"}}
  ]
}
